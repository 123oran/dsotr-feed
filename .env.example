# /api/publish — Instagram Graph API credentials
# Copy this to .env for local `vercel dev`, and set the same keys in the Vercel
# project (Settings -> Environment Variables). NEVER commit real values.

# The Instagram Business/Creator account's user-id (the IG user id, not a FB id).
IG_USER_ID=

# Long-lived access token with instagram_basic + instagram_content_publish, for a
# Meta app that has your IG account added (admin/developer/tester) in Dev mode.
IG_ACCESS_TOKEN=

# Optional — Graph API version. Bump if v21.0 is retired.
GRAPH_VERSION=v21.0

# Optional — public base URL of the DEPLOYMENT (fallback for building media URLs).
# Leave empty on Vercel (derived from the request).
PUBLIC_BASE_URL=

# Where the clips are hosted. The 50 HD clips are too big for the Vercel deploy,
# so they live on GitHub Releases. Set this to the release download base (the app
# appends /<issue>-<model>-<mode>.mp4). Leave empty to serve from /media on the
# deployment instead.
#   e.g. https://github.com/123oran/dsotr-feed/releases/download/clips
MEDIA_BASE_URL=
