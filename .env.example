# Instagram publishing + "Log in with Instagram" — set these in the Vercel project
# (Settings -> Environment Variables). Copy to .env for local `vercel dev`.
# NEVER commit real values.

# --- Instagram Login (OAuth) — lets any Business/Creator account connect ---
# From your Meta app: Instagram product -> "API setup with Instagram business login".
IG_APP_ID=
IG_APP_SECRET=

# Random 32+ char secret used to encrypt the session cookie (any long random string):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# --- Default account (used when nobody has connected via the login flow) ---
# Your own IG Business/Creator account. The token must be an INSTAGRAM-LOGIN token
# (instagram_business_content_publish, via graph.instagram.com) — NOT a Facebook-Graph
# token. Easiest: connect once through the app's own login flow, or use the app's
# Instagram-login token generator.
IG_USER_ID=
IG_ACCESS_TOKEN=
# Optional — your @handle, shown in the UI as the default ("Posting to @you").
IG_DEFAULT_USERNAME=

# --- Media hosting ---
# Release download base where the 50 clips live (app appends /<issue>-<model>-<mode>.mp4).
MEDIA_BASE_URL=https://github.com/123oran/dsotr-feed/releases/download/clips

# Optional — public base URL of the deployment (else derived from the request).
# Used for the OAuth redirect_uri and media fallback; usually leave empty on Vercel.
PUBLIC_BASE_URL=
