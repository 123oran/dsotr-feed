{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/publish.js": { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/assets/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/media/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
